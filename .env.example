# Hammershift Admin - Environment Variables Template
# Copy this file to .env.local for development
# Production: all vars are set in AWS Amplify Console > Environment Variables

# ============================================
# DATABASE (existing - already in Amplify)
# ============================================
MONGODB_URI=mongodb+srv://...
DB_NAME=hammershift

# ============================================
# AUTH (existing - already in Amplify)
# ============================================
# Note: Amplify uses AUTH_SECRET (not NEXTAUTH_SECRET)
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_URL=https://main.d3bje0ak6q49bm.amplifyapp.com/

# ============================================
# FIREBASE (existing - already in Amplify)
# ============================================
# Note: Amplify uses FIREBASE_* (no NEXT_PUBLIC_ prefix needed server-side)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=velocity-markets.firebaseapp.com
FIREBASE_PROJECT_ID=velocity-markets
FIREBASE_STORAGE_BUCKET=velocity-markets.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# GEMINI (existing - already in Amplify)
# ============================================
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

# ============================================
# CUSTOMER.IO INTEGRATION (NEW - add to Amplify)
# ============================================
# Get from: Customer.io dashboard > Settings > API Credentials
CUSTOMERIO_SITE_ID=your_site_id_here
CUSTOMERIO_API_KEY=your_api_key_here
# Get from: Customer.io dashboard > Settings > Webhooks
CUSTOMERIO_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# POSTHOG ANALYTICS (NEW - add to Amplify)
# ============================================
# Get from: PostHog dashboard > Project Settings > Project API Key
POSTHOG_API_KEY=your_posthog_project_key_here
POSTHOG_HOST=https://app.posthog.com

# ============================================
# EMAIL / RESEND (required for password reset OTPs)
# ============================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Optional: Override default from email (defaults to noreply@velocity-markets.com)
RESEND_FROM_EMAIL=noreply@velocity-markets.com

# ============================================
# CRON JOBS (NEW - add to Amplify + GitHub Secrets)
# ============================================
# IMPORTANT: Must also be added as GitHub Actions secret (CRON_SECRET + APP_URL)
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ============================================
# SCRAPER WEBHOOK (NEW - add to Amplify)
# ============================================
# Shared secret for verifying webhook requests from the scraper oracle module
# The scraper sends this in X-Scraper-Secret header when posting hammer prices
# Generate: openssl rand -hex 32
# IMPORTANT: Must match WEBHOOK_SECRET in scraper's .env
SCRAPER_SECRET=your_scraper_webhook_secret_here

# ============================================
# ORACLE SIGNATURE VERIFICATION (CRITICAL - add to Amplify)
# ============================================
# Oracle's public address for signature verification
# This is the address derived from the scraper's ORACLE_PRIVATE_KEY
# IMPORTANT: Must match the oracle address set in MarketResolver contract constructor
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon RPC endpoint for calling MarketResolver contract
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# MarketResolver contract address on Polygon
MARKET_RESOLVER_ADDRESS=0x0000000000000000000000000000000000000000
